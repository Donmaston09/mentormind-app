AI_PROVIDER=gemini

# Add at least one provider key. The selected provider is controlled by
# AI_PROVIDER on the server or by the in-app Settings screen per user.
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional model overrides
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-latest

PORT=3000
